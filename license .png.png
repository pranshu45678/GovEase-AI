GHUs5J04Qye0OegoIAggACAEIBhAK" data-hveid="CAIIAAgBCAYQCg"><span class="pxxQye T6UJT"><div class="a14YJe" jsaction="" jscontroller="sRLmTc#WhfBh" data-sfc-root="c" jsuid="QG8fV_n" data-sfc-cb=""><svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" height="12px" viewBox="0 -960 960 960" width="12px"><path d="M440-280H280q-83 0-141.5-58.5T80-480q0-83 58.5-141.5T280-680h160v80H280q-50 0-85 35t-35 85q0 50 35 85t85 35h160v80ZM320-440v-80h320v80H320Zm200 160v-80h160q50 0 85-35t35-85q0-50-35-85t-85-35H520v-80h160q83 0 141.5 58.5T880-480q0 83-58.5 141.5T680-280H520Z"></path></svg><!--TgQPHd||[]--></div></span><div jsuid="QG8fV_k" style="display: none;" data-ved="2ahUKEwi9lf-P_t2VAxU_7TgGHUs5J04QlZkRegoIAggACAEIBhAL"></div></button></span><!--TgQPHd||[[&quot;0ecb76d5-7102-4975-8ba9-2a2f26aae99c&quot;,null,null,0,&quot;&quot;,&quot;&quot;,0,null,null,null,null,0]]--></span><!--TgQPHd||[]--></div><ul class="KsbFXc U6u95" jsaction="" jscontroller="mPWODf#NS0kde" data-sfc-root="ep" jsuid="QG8fV_o" data-sfc-cb="" data-ved="2ahUKEwi9lf-P_t2VAxU_7TgGHUs5J04Q-7AUegoIAggACAEIBhAM" data-hveid="CAIIAAgBCAYQDA"><div data-bfc="" class="" data-ved="2ahUKEwi9lf-P_t2VAxU_7TgGHUs5J04Qi4wTegoIAggACAEIBhAN"><li class="Z1qcYe" data-sfc-cp="" jsaction="" jscontroller="oSLmPe#HokZ0d" data-sfc-root="ep" jsuid="QG8fV_p" data-sfc-cb="" data-hveid="CAIIAAgBCAYQDg"><span class="T286Pc" data-sfc-cp="" jsaction="" jscontroller="fly6D#d5Qebf" data-sfc-root="ep" jsuid="QG8fV_q" data-sfc-cb=""><strong class="Yjhzub" jsaction="" jscontroller="zYmgkd#vvzi1e" data-sfc-root="ep" jsuid="QG8fV_r" data-sfc-cb="">Dimensions:<!--TgQPHd||[]--></strong> 35mm width × 45mm height.<!--TgQPHd||[]--></span><!--TgQPHd||[]--></li></div><div data-bfc="" class="" data-ved="2ahUKEwi9lf-P_t2VAxU_7TgGHUs5J04Qi4wTegoIAggACAEIBhAP"><li class="Z1qcYe" data-sfc-cp="" jsaction="" jscontroller="oSLmPe#HokZ0d" data-sfc-root="ep" jsuid="QG8fV_s" data-sfc-cb="" data-hveid="CAIIAAgBCAYQEA"><span class="T286Pc" data-sfc-cp="" jsaction="" jscontroller="fly6D#d5Qebf" data-sfc-root="ep" jsuid="QG8fV_t" data-sfc-cb=""><strong class="Yjhzub" jsaction="" jscontroller="zYmgkd#vvzi1e" data-sfc-root="ep" jsuid="QG8fV_u" data-sfc-cb="">Head size:<!--TgQPHd||[]--></strong> Your head, from chin to crown, should take up 25mm to 35mm of the photo’s height.<!--TgQPHd||[]--></span><!--TgQPHd||[]--></li></div><div data-bfc="" class="WYczDe" data-ved="2ahUKEwi9lf-P_t2VAxU_7TgGHUs5J04Qi4wTegoIAggACAEIBhAR" ahbak="true" aria-hidden="true"><li class="Z1qcYe" data-sfc-cp="" jsaction="" jscontroller="oSLmPe#HokZ0d" data-sfc-root="ep" jsuid="QG8fV_v" data-sfc-cb="" data-hveid="CAIIAAgBCAYQEg"><span class="T286Pc" data-sfc-cp="" jsaction="" jscontroller="fly6D#d5Qebf" data-sfc-root="ep" jsuid="QG8fV_w" data-sfc-cb=""><strong class="Yjhzub" jsaction="" jscontroller="zYmgkd#vvzi1e" data-sfc-root="ep" jsuid="QG8fV_x" data-sfc-cb="">Background:<!--TgQPHd||[]--></strong> Must be plain white with no textures or shadows.<!--TgQPHd||[]--></span><!--TgQPHd||[]--></li></div><div data-bfc="" class="WYczDe" data-ved="2ahUKEwi9lf-P_t2VAxU_7TgGHUs5J04Qi4wTegoIAggACAEIBhAT" ahbak="true" aria-hidden="true"><li class="Z1qcYe" data-sfc-cp="" jsaction="" jscontroller="oSLmPe#HokZ0d" data-sfc-root="ep" jsuid="QG8fV_y" data-sfc-cb="" data-hveid="CAIIAAgBCAYQFA"><span class="T286Pc" data-sfc-cp="" jsaction="" jscontroller="fly6D#d5Qebf" data-sfc-root="ep" jsuid="QG8fV_z" data-sfc-cb=""><strong class="Yjhzub" jsaction="" jscontroller="zYmgkd#vvzi1e" data-sfc-root="ep" jsuid="QG8fV_10" data-sfc-cb="">Expression:<!--TgQPHd||[]--></strong><div style="display: contents" id="sdh_hV1caubzEtCu4-EPtPne-A4_1"> Maintain a neutral facial expression with your eyes open and looking straight at the camera.</div><!--TgQPHd||[]--></span><!--TgQPHd||[]--></li></div><div style="display: contents" id="sdh_hV1caubzEtCu4-EPtPne-A4_2"><div data-bfc="" class="WYczDe" data-ved="2ahUKEwi9lf-P_t2VAxU_7TgGHUs5J04Qi4wTegoIAggACAEIFhAA" ahbak="true" aria-hidden="true"><li class="Z1qcYe" data-sfc-cp="" jsaction="" jscontroller="oSLmPe#HokZ0d" data-sfc-root="ep" jsuid="QG8fV_6v" data-sfc-cb="" data-hveid="CAIIAAgBCBYQAQ"><span class="T286Pc" data-sfc-cp="" jsaction="" jscontroller="fly6D#d5Qebf" data-sfc-root="ep" jsuid="QG8fV_6w" data-sfc-cb=""><strong class="Yjhzub" jsaction="" jscontroller="zYmgkd#vvzi1e" data-sfc-root="ep" jsuid="QG8fV_6x" data-sfc-cb="">Clothing:<!--TgQPHd||[]--></strong> Wear clothes that contrast against the white background (avoid wearing white).<!--TgQPHd||[]--></span><!--TgQPHd||[]--></li></div><div data-bfc="" class="WYczDe" data-ved="2ahUKEwi9lf-P_t2VAxU_7TgGHUs5J04Qi4wTegoIAggACAEIFhAC" ahbak="true" aria-hidden="true"><li class="Z1qcYe" data-sfc-cp="" jsaction="" jscontroller="oSLmPe#HokZ0d" data-sfc-root="ep" jsuid="QG8fV_6y" data-sfc-cb="" data-hveid="CAIIAAgBCBYQAw"><span class="T286Pc" data-sfc-cp="" jsaction="" jscontroller="fly6D#d5Qebf" data-sfc-root="ep" jsuid="QG8fV_6z" data-sfc-cb=""><strong class="Yjhzub" jsaction="" jscontroller="zYmgkd#vvzi1e" data-sfc-root="ep" jsuid="QG8fV_70" data-sfc-cb="">Accessories:<!--TgQPHd||[]--></strong> No hats or head coverings unless worn daily for religious purposes. Prescription glasses are allowed, but they must not cause glare or obscure your eyes.<!--TgQPHd||[]--></span><span jsuid="QG8fV_71" class="WBgIic Wg1cdb notranslate" jsaction="rcuQ6b:&amp;QG8fV_71|npT2md" jscontroller="XqmSxe#JjQTXe" data-sfc-root="ep" data-wiz-uids="QG8fV_72,QG8fV_73,QG8fV_74" data-sfc-cb="" data-sfc-inited="2"><span class="NMq1me" data-animation-atomic="" jsaction="click:&amp;QG8fV_71|QNgZi"><span aria-hidden="true">&nbsp;</span><!--qkimaf QG8fV_71/HugV6--><a jsuid="QG8fV_74" class="PMDqCb" target="_blank" rel="noopener" aria-label="Visafoto.com (+4) – View related links" jsaction="mouseenter:&amp;QG8fV_71|sbHm2b;mouseleave:&amp;QG8fV_71|Tx5Rb" data-ved="2ahUKEwi9lf-P_t2VAxU_7TgGHUs5J04Q0YISegoIAggACAEIFhAE" href="https://visafoto.com/india/driving-license-application" ping="/